# NovaMind Environment Variables Template
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit your actual '.env' file containing secrets to GitHub!

# Groq Cloud API Key (Required for Generative QA fallback)
# Create a key at: https://console.groq.com/
GROQ_API_KEY="your_groq_api_key_here"

# Security & API Protection Configuration
# ----------------------------------------------------
# Pre-shared Bearer token used to secure endpoints (e.g. standard API key)
# Leave blank or undefined to bypass authorization in local development
API_AUTH_TOKEN="your_secure_pre_shared_bearer_token_here"

# Frontend Bearer token mapping for Vite build
# This must match API_AUTH_TOKEN so the React client can authenticate successfully
VITE_API_AUTH_TOKEN="your_secure_pre_shared_bearer_token_here"

# CORS configuration: comma-separated list of trusted client origins
ALLOWED_ORIGINS="http://localhost:5000"
